# Proyecto
APP_NAME=VERIGRAPH
APP_ENV=local
APP_DEBUG=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_PORT=8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-local-secret
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_ISSUER=http://localhost:8080/realms/verigraph
KEYCLOAK_CLIENT_ID=verigraph-web
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_AUTO_PROVISION_USERS=true
NEXT_PUBLIC_KEYCLOAK_ENABLED=false

# API
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=change-me-local-jwt-secret
JWT_ISSUER=verigraph-local
ACCESS_TOKEN_EXPIRE_MINUTES=60
WORKER_API_TOKEN=

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=verigraph
POSTGRES_USER=verigraph
POSTGRES_PASSWORD=verigraph
DATABASE_URL=postgresql+asyncpg://verigraph:verigraph@postgres:5432/verigraph

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=verigraph-local

# MinIO / S3
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET_EVIDENCE=verigraph-evidence
S3_ACCESS_KEY=verigraph
S3_SECRET_KEY=verigraph-local
S3_REGION=us-east-1
EVIDENCE_STORAGE_BACKEND=local

# Analisis de evidencia: OCR (Tesseract) + AI Vision (Anthropic)
ANTHROPIC_API_KEY=
CLAUDE_VISION_MODEL=claude-sonnet-5
OCR_LANGUAGE=spa+eng
OCR_MIN_CONFIDENCE=60.0
OCR_MIN_WORD_COUNT=3

# Fuentes externas
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
PHISHTANK_API_KEY=
URLHAUS_AUTH_KEY=
URLSCAN_API_KEY=
SLACK_WEBHOOK_URL=

# Alertas salientes
NOTIFICATION_WEBHOOK_URL=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=alerts@verigraph.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Seguridad
RATE_LIMIT_PER_MINUTE=60
MAX_EVIDENCE_UPLOAD_MB=20
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1|\[::1\]|10\.\d{1,3}\.\d{1,3}\.\d{1,3}|192\.168\.\d{1,3}\.\d{1,3}|172\.(1[6-9]|2\d|3[0-1])\.\d{1,3}\.\d{1,3})(:\d+)?
PRIVACY_COUNTRY=PE
PRIVACY_LAW=LEY_29733
