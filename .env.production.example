# Copia este archivo como .env.production en el servidor y cambia los secretos.

APP_NAME=VERIGRAPH
APP_ENV=production
APP_DEBUG=false

# Dominio publico. Cambia ejemplo.com por tu dominio o IP mientras pruebas.
PUBLIC_WEB_URL=http://TU_IP_O_DOMINIO:3000
PUBLIC_API_URL=http://TU_IP_O_DOMINIO:8000

NEXT_PUBLIC_API_URL=http://TU_IP_O_DOMINIO:8000
NEXT_PUBLIC_API_PORT=8000
NEXTAUTH_URL=http://TU_IP_O_DOMINIO:3000
NEXTAUTH_SECRET=CAMBIA_ESTE_SECRET_LARGO
NEXT_PUBLIC_KEYCLOAK_ENABLED=false

API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=CAMBIA_ESTE_JWT_SECRET_LARGO
JWT_ISSUER=verigraph-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
WORKER_API_TOKEN=CAMBIA_ESTE_TOKEN_WORKER
CORS_ORIGINS=["http://TU_IP_O_DOMINIO:3000"]
CORS_ORIGIN_REGEX=

POSTGRES_DB=verigraph
POSTGRES_USER=verigraph
POSTGRES_PASSWORD=CAMBIA_ESTE_PASSWORD_POSTGRES
DATABASE_URL=postgresql+asyncpg://verigraph:CAMBIA_ESTE_PASSWORD_POSTGRES@postgres:5432/verigraph

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CAMBIA_ESTE_PASSWORD_NEO4J

MINIO_ROOT_USER=verigraph
MINIO_ROOT_PASSWORD=CAMBIA_ESTE_PASSWORD_MINIO
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://TU_IP_O_DOMINIO:9000
S3_BUCKET_EVIDENCE=verigraph-evidence
S3_ACCESS_KEY=verigraph
S3_SECRET_KEY=CAMBIA_ESTE_PASSWORD_MINIO
S3_REGION=us-east-1
EVIDENCE_STORAGE_BACKEND=local

KEYCLOAK_ISSUER=
KEYCLOAK_CLIENT_ID=verigraph-web
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_AUTO_PROVISION_USERS=true

VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
PHISHTANK_API_KEY=
URLHAUS_AUTH_KEY=
URLSCAN_API_KEY=
SLACK_WEBHOOK_URL=

NOTIFICATION_WEBHOOK_URL=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=alerts@verigraph.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

RATE_LIMIT_PER_MINUTE=60
MAX_EVIDENCE_UPLOAD_MB=20
PRIVACY_COUNTRY=PE
PRIVACY_LAW=LEY_29733
